<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_order_form_order_type_inherit" model="ir.ui.view">
            <field name="name">view_order_form_order_type</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='user_id']" position="attributes">
                    <attribute name="options">{'no_create': True,'no_edit':True}</attribute>
                </xpath>
                <xpath expr="//form/sheet//field[@name='order_line']//list//field[@name='product_id']" position="attributes">
                    <attribute name="options">{'no_create': True,'no_edit':True}</attribute>
                </xpath>
                <xpath expr="//form/sheet//field[@name='order_line']//list//field[@name='product_template_id']" position="attributes">
                    <attribute name="options">{'no_create': True,'no_edit':True}</attribute>
                </xpath>
            </field>                   
        </record>

        <record id="view_sale_sale_order_form_quote_inherit" model="ir.ui.view">
            <field name="name">view_sale.order.form.payment</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale_management.sale_order_form_quote"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='sale_order_option_ids']//list//field[@name='product_id']" position="attributes">
                    <attribute name="options">{'no_create': True,'no_edit':True}</attribute>
                </xpath>

                <xpath expr="//field[@name='sale_order_option_ids']//list//field[@name='uom_id']" position="attributes">
                    <attribute name="options">{'no_create': True,'no_edit':True}</attribute>
                </xpath>
            </field>                   
        </record>

        <record id="view_sale_sale_order_doc_type" model="ir.ui.view">
            <field name="name">view_sale.order.form.doc.type</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="/form/sheet/notebook/page[2]/group//field[@name='user_id']" position="after">
                    <field name="y_parent_company_id" invisible="1"/>
                    <field name="y_sale_doc_type_id" options="{'no_create': True,'no_open': True,'no_create_edit':True}"/>
                </xpath>
            </field>                   
        </record>
    </data>
</odoo> 