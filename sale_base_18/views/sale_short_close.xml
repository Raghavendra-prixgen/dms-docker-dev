
<odoo>
	  <record model="ir.ui.view" id="sale_order_form_short_close">
      <field name="name">sale.order.short.close</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">
        <xpath expr="//page[@name='other_information']/group/group[2]" position="inside">
          <field name = "y_short_close_reason" invisible="1" readonly="1"/>
        </xpath>
        <xpath expr="//field[@name='order_line']/list/field[@name='tax_id']" position="after">
          <field name = "y_is_short_close" readonly="1" optional="hide"/>
          <field name = "y_short_close_description" optional="hide"/>
        </xpath>
      </field>
    </record>

    <record model="ir.ui.view" id="sale_order_form_so_short_close_tree">
      <field name="name">sale.order.short.close.so.list</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_tree"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='state']" position="after">
          <field name = "y_is_so_short_close" optional="hide"/>
        </xpath>
      </field>
    </record>

    <record model="ir.actions.server" id="action_short_close_sale_order">
      <field name="name">Short Close</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="binding_model_id" ref="sale.model_sale_order"/>
      <field name="binding_view_types">form</field>
      <field name="state">code</field>
      <field name="code">
			  if records:
  				action = records.short_close_form_wizard_sale()
      </field>
    </record>

</odoo>
