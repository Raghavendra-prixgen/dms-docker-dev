<odoo>
	<record id="view_saleorder_short_close_wizard_form" model="ir.ui.view">
        <field name="name">saleorder.short.close.wizard.form</field>
        <field name="model">saleorder.short.close.wizard</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <group>
                    <group>
                        <field name="y_order_id" invisible="1" />
                        <field name="y_short_close_reason" invisible="1" string="Short Close Reason"/>
                    </group>
                </group>
                <!-- <label for="sc_so_lines_ids"/> -->
                <field name="y_sc_so_lines_ids" domain="[('order_id','=',y_order_id),('y_is_short_close','=',False)]"  string="Short Close SO Lines">
                    <list editable="bottom" create="0" >
                        <field name="order_id" readonly="1"/>
                        <field name="order_partner_id" readonly="1"/>
                        <field name="product_id" readonly="1"/>
                        <field name="product_uom_qty" readonly="1"/>
                        <field name="qty_delivered" readonly="1"/>
                        <field name="qty_invoiced" readonly="1"/>
                        <field name="y_is_short_close"/>
                        <field name="y_short_close_reason_id" required="1" attrs="{'required':[('y_is_short_close','=',True)]}"/>
                        <!-- <field name="date_planned" readonly="1"/> -->
                        <field name="price_unit" readonly="1"/>
                        <field name="price_subtotal" readonly="1"/>                
                    </list>
                </field>           
                <footer>
                    <group>
                        <button class="btn btn-primary" type="object" name="button_action_short_close" string="Confirm"/>
                    </group>
                </footer>
            </form>

        </field>
    </record>

    <record id="sales_short_close_reason_tree_view" model="ir.ui.view">
        <field name="name">sales.short.close.reason.view.list</field>
        <field name="model">sales.short.close.reason</field>
        <field name="arch" type="xml">
            <list editable="bottom" duplicate="0">
                <field name="y_name"/>
            </list>
        </field>
    </record>

    <record id="sales_short_close_reason_action" model="ir.actions.act_window">
        <field name="name">Short Close Reasons For SO</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sales.short.close.reason</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_config_sales_short_close_reason"
              name="Short Close Reasons For SO"
              parent="sale_base_18.menu_config_sale_others"
              action="sales_short_close_reason_action"
              sequence="110"/>  

</odoo>