<odoo>
    
    <record id="distributor_invoice_report_wizard_view_form" model="ir.ui.view">
        <field name="name">distributor.invoice.report.wizard.form</field>
        <field name="model">distributor.invoice.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Invoice Report Form">
                <group>
                    <field name="y_project_report_printed" invisible="1"/> 
                    <group>
                        <field name="y_start_date" required="1" invisible="y_project_report_printed == True"/>
                        <field name="y_company_ids" options="{'no_create': True, 'no_create_edit':True, 'no_open': True}" required="1" invisible="y_project_report_printed == True" widget="many2many_tags" string="Distributor"/>
                    </group>
                    <group >
                        <field name="y_end_date" required="1" invisible="y_project_report_printed == True"/>
                        <field name="y_move_type" string="Customer Type" invisible="y_project_report_printed == True"/>
                    </group>       
                    <group>
                        <field name="y_invoice_status" invisible="y_project_report_printed == True" />
                    </group>      
                </group>
                <group >
                        <field name="y_file_name" invisible="1"/>
                        <field name="y_project_report" readonly="1" filename="y_file_name" invisible="y_project_report_printed == False"/>
                </group>
                <footer>
                    <button string="Generate Report" type="object" name="get_distributor_invoice_report" class="oe_highlight"/>
                    <button string="Cancel" special="cancel" type="object" class="btn btn-secondary oe_inline"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_distributor_invoice_report_wizard" model="ir.actions.act_window">
        <field name="name">Invoice Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">distributor.invoice.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="distributor_invoice_report_wizard_view_form"/>
        <field name="target">new</field>
    </record>
    
    
    <menuitem id="menu_distributor_invoice_report_wizard"
            name="Invoice Report"
            action="action_distributor_invoice_report_wizard"
            parent="account.menu_finance_reports"
            sequence="2"/>
    
</odoo>