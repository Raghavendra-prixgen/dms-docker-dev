<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <template id="right_login_layout" name="right Login Layout">
        <t t-call="web.frontend_layout">
            <t t-set="html_data" t-value="{'style': 'height: 100%;'}"/>
            <t t-set="body_classname" t-value="'bg-200'"/>
            <t t-set="no_header" t-value="True"/>
            <t t-set="no_footer" t-value="True"/>
            <div class="background" style="background-image: url('/odoo_custom_login_inf/static/description/BG.jpg'); background-size: cover; background-position: center;">
                <div class="container body_login" style="height: 100%;">
                    <div id="bcard" t-attf-class="card d-flex align-items-center border-0 mx-auto bg-200 {{login_card_classes}} o_database_list" style="float:right; box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);">
                        <div class="card-body">
                            <div>
                                <div t-attf-class="text-center pb-3 border-bottom">
                                    <img t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}" alt="Logo" style="max-height:100px; max-width: 100%; width:auto;"/>
                                </div>
                                <t t-raw="0"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="odoo_custom_login_inf.right_login_template" name="Login">
        <t t-call="odoo_custom_login_inf.right_login_layout">
            <form class="oe_login_form" role="form" t-attf-action="/web/login" method="post" onsubmit="this.action = '/web/login' + location.hash">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                <div class="form-group field-db" t-if="databases and len(databases) &gt; 1">
                    <div t-attf-class="input-group {{'input-group-sm' if form_small else ''}}">
                        <input type="text" name="db" t-att-value="request.db" id="db" t-attf-class="form-control #{'form-control-sm' if form_small else ''}" required="required" readonly="readonly"/>
                        <span class="input-group-append">
                            <a role="button" href="/web/database/selector" class="btn btn-secondary">Select <i class="fa fa-database" role="img" aria-label="Database" title="Database"></i>
                            </a>
                        </span>
                    </div>
                </div>

                <div class="mb-3 field-login">
                    <label for="login" class="form-label mx-1">
                        <b class="">Email</b>
                    </label>

                    <div class="email_div">
                        <i class="fa fa-envelope icon m-auto"></i>
                        <input type="text" placeholder="Email" name="login" t-att-value="login" id="login" t-attf-class="form-control #{'form-control-sm' if form_small else ''} email_input" required="required" autocomplete="username" autocapitalize="off" style=""/>
                    </div>
                </div>
                <div class="mb-3 field-login">
                    <label for="password" class="form-label mx-1">
                        <b class="">Password</b>
                    </label>

                    <div class="password_div">
                        <i class="fa fa-key icon m-auto"></i>
                        <input type="password" placeholder="Password" name="password" id="password" t-attf-class="form-control #{'form-control-sm' if form_small else ''} password_input" required="required" autocomplete="current-password" t-att-autofocus="'autofocus' if login else None" maxlength="4096" style=""/>
                    </div>
                </div>

                <p class="alert alert-danger" t-if="error" role="alert">
                    <t t-esc="error"/>
                </p>
                <p class="alert alert-success" t-if="message" role="status">
                    <t t-esc="message"/>
                </p>

                <div t-attf-class="clearfix oe_login_buttons text-center mb-1 {{'pt-2' if form_small else 'pt-3'}}">
                    <button type="submit" class="btn btn-block login_button my-3" style="border-radius: 20px; box-shadow: 0 0 10px rgba(0, 0, 0, 0.2);">Log in</button>
                    <br class=""/>
                    <t t-if="debug">
                        <button type="submit" name="redirect" value="/web/become" class="btn btn-link btn-sm btn-block">Log in as superuser</button>
                    </t>
                    <div class="justify-content-between mt-2 d-flex small">
                        <a t-if="signup_enabled" t-attf-href="/web/signup?{{ keep_query() }}" style="color: #6c757d;">Don't have an account?</a>
                        <a t-if="reset_password_enabled" t-attf-href="/web/reset_password?{{ keep_query() }}" style="color: #6c757d;">Reset Password</a>
                    </div>
                    <div class="o_login_auth"/>
                </div>

                <input type="hidden" name="redirect" t-att-value="redirect"/>
            </form>
        </t>
    </template>
</odoo>