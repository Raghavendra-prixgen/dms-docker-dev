<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_users_form_view_approval_code" model="ir.ui.view">
        <field name="name">res.users.list.view</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//div[hasclass('oe_title')]/group/field[@name='partner_id']" position="after">                
                <field name="y_user_code_ids" widget="many2many_tags" options="{'no_create': True, 'no_open': True}" />
            </xpath>
        </field>
    </record>

    <record id="res_users_view_approval_code_tree" model="ir.ui.view">
        <field name="name">res.users.list.approval.view</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record model="ir.ui.view" id="search_user_approval_code">
        <field name="name">user.approval.code.search</field>
        <field name="model">user.approval.code</field>
        <field name="arch" type="xml">
            <search>
              <field name="y_code"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    
    
    <record id="user_approval_code_tree_view" model="ir.ui.view">
        <field name="name">user.approval.code.list.view</field>
        <field name="model">user.approval.code</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="y_code"/>
                <field name="y_description"/>
                <field name="y_model_ids" required="1" options="{'no_create': True, 'no_create_edit':True}" widget="many2many_tags"/>
                <field name="y_activity_type_id" required="1" options="{'no_create': True, 'no_create_edit':True}"/>
            </list>
        </field>
    </record>

    <record id="user_approval_code_group_action" model="ir.actions.act_window">
        <field name="name">Approval Code</field>
        <field name="res_model">user.approval.code</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="user_approval_code_tree_view"/>
    </record>

    <menuitem id="menu_user_approval_code_group" name="Approval Code"
                action="user_approval_code.user_approval_code_group_action" 
                parent="base.menu_users"
                sequence="102"/>
    
</odoo>