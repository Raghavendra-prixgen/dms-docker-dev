
<!-- <?xml version="1.0" encoding="utf-8"?> -->
<odoo>

    <record id="view_move_line_tree_view_custom" model="ir.ui.view">
        <field name="name">account.move.line.tree.view</field>
        <field name="model">account.move.line</field>
        <!-- <field eval="100" name="priority"/> -->
        <field name="arch" type="xml">
            <list string="DMS Report" create="false" edit="false">
                <field name="move_name"/>
                <field name="company_id" string="Distributor Name"/>
                <field name="partner_id" string="Customer Name"/>
                <field name="product_display_name" string="Product Display Name"/>
                <field name="product_reference"/>
                <field name="name" string="Tally product name"/>
                <field name="tally_invoice_number"/>
            </list>
        </field>
    </record>

    <record id="action_distributor_invoice_line_report" model="ir.actions.act_window">
        <field name="name">DMS Report</field>
        <!-- <field name="type">ir.actions.act_window</field> -->
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="dms_invoice_report.view_move_line_tree_view_custom"/>
        <field name="target">current</field>
        <field name="domain">[('parent_state', '=', 'posted'),('move_type', '=', 'out_invoice'),('display_type','=','product')]</field>
    </record>


    <menuitem id="menu_distributor_invoice_line_report"
            name="DMS Report"
            action="action_distributor_invoice_line_report"
            parent="account.menu_finance_reports"
            sequence="2"/>
</odoo>