<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_publish_distributor_wizard_form" model="ir.ui.view">
        <field name="name">publish.distributor.wizard.form</field>
        <field name="model">publish.distributor.wizard</field>
        <field name="arch" type="xml">
            <form string="Publish Distributor">
                <group>
                    <field name="distributor_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="publish_record" string="Publish" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    

</odoo>