<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Add Tally Sync fields to Product Form View -->
    <record id="view_product_form_tally_sync" model="ir.ui.view">
        <field name="name">product.product.form.tally.sync</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            
            <!-- Add button to reset sync status -->
            <xpath expr="//header" position="inside">
                <button name="action_reset_sync_status" 
                        string="Reset Sync Status" 
                        type="object"
                        invisible="tally_sync_status != 'failed'"
                        class="btn-warning"/>
            </xpath>
            
            <!-- Add Tally Sync page -->
            <xpath expr="//notebook" position="inside">
                <page string="Tally Sync" name="tally_sync">
                    <group>
                        <group>
                            <field name="tally_sync_status" 
                                   widget="badge"
                                   decoration-success="tally_sync_status == 'synced'"
                                   decoration-warning="tally_sync_status == 'pending'"
                                   decoration-danger="tally_sync_status == 'failed'"/>
                            <field name="last_tally_sync_date"/>
                        </group>
                        <group>
                            <field name="tally_sync_message" 
                                   widget="text"
                                   invisible="not tally_sync_message"/>
                        </group>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>
    
    <!-- Add Tally Sync fields to Product list View (Odoo 18 uses list, not list) -->
    <record id="view_product_list_tally_sync" model="ir.ui.view">
        <field name="name">product.product.list.tally.sync</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
    
            <!-- Decorations -->
            <xpath expr="//list" position="attributes">
                <attribute name="decoration-success">tally_sync_status == 'synced'</attribute>
                <attribute name="decoration-warning">tally_sync_status == 'pending'</attribute>
                <attribute name="decoration-danger">tally_sync_status == 'failed'</attribute>
            </xpath>
    
            <!-- Add fields after name -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="tally_sync_status" widget="badge" optional="show"/>
                <field name="last_tally_sync_date" optional="hide"/>
            </xpath>
    
        </field>
    </record>
    
    
    
    <!-- Add Tally Sync fields to Product Template Form View -->
    <record id="view_product_template_form_tally_sync" model="ir.ui.view">
        <field name="name">product.template.form.tally.sync</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Tally Sync" name="tally_sync">
                    <group>
                        <group>
                            <field name="tally_sync_status" 
                                   widget="badge"
                                   decoration-success="tally_sync_status == 'synced'"
                                   decoration-warning="tally_sync_status == 'pending'"
                                   decoration-danger="tally_sync_status == 'failed'"/>
                            <field name="last_tally_sync_date"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
    
    <!-- Search view with Tally Sync filters -->
    <record id="view_product_search_tally_sync" model="ir.ui.view">
        <field name="name">product.product.search.tally.sync</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_search_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='inactive']" position="after">
                <separator/>
                <filter string="Pending Sync" 
                        name="tally_pending" 
                        domain="[('tally_sync_status', '=', 'pending')]"/>
                <filter string="Synced" 
                        name="tally_synced" 
                        domain="[('tally_sync_status', '=', 'synced')]"/>
                <filter string="Failed Sync" 
                        name="tally_failed" 
                        domain="[('tally_sync_status', '=', 'failed')]"/>
            </xpath>
            <xpath expr="//filter[@name='categ_id']" position="after">
                <filter string="Sync Status" 
                        name="group_by_sync_status" 
                        context="{'group_by': 'tally_sync_status'}"/>
            </xpath>
        </field>
    </record>

</odoo>