<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="form_create_sale_quotation" model="ir.ui.view">
        <field name="name">form.create.sale.quotation</field>
        <field name="model">create.sale.quotation</field>
        <field name="arch" type="xml">
            <form string="Create Sale Quotation">
                <field name="y_line_ids">
                    <list create="false" editable="bottom">
                        <field name="y_create_quote_id" column_invisible="True"/>
                        <field name="y_sale_line_id" column_invisible="True"/>
                        <field name="y_product_id" readonly="1"/>
                        <field name="y_partner_id" options="{'no_create': True}"/>
                        <field name="y_remaining_qty" readonly="1"/>
                        <field name="y_order_qty"/>
                    </list>
                </field>
                <footer>
                    <button string="Create Quotation" name="create_quotation" type="object" class="oe_highlight"/>&#160;&#160;
                    <button string="Close Window" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_create_sale_quotation" model="ir.actions.act_window">
        <field name="name">Create Sale Quotation</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">create.sale.quotation</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="form_create_sale_quotation"/>
        <field name="binding_model_id" ref="sale_base_18.model_create_sale_quotation"/>
    </record>
</odoo>