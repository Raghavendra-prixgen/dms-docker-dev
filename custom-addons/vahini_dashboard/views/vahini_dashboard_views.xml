<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="vahini_dashboard_action" model="ir.actions.client">
        <field name="name">Vahini Dashboard</field>
        <field name="tag">vahini_dashboard</field>
        <field name="target">fullscreen</field>
    </record>

    <menuitem
        id="vahini_dashboard_menu_root"
        name="Vahini Dashboard"
        sequence="200"
    />

    <menuitem
        id="vahini_dashboard_menu_snap"
        name="Vahini Dashboard"
        parent="vahini_dashboard_menu_root"
        action="vahini_dashboard_action"
        sequence="1"
    />
</odoo>
