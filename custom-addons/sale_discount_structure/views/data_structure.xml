<odoo>
	<data>	
		
 		<record id="sh_pol_data_structure_inherit" model="ir.ui.view">
			<field name="name">discount structure</field>
			<field name="model">discount.structure</field>
			<field name="arch" type="xml">			
				<form string="Discount Structure">
                    <header>
                        <!-- <button id = "button_draft" name = "action_draft" type = "object" string = "Save"  /> -->
                        <button id = "button_confirm" name = "action_confirm" type = "object" string = "Confirm"  />
                        <field name= "y_state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="y_price_id" />
                                <field name="y_doc_type_id"  options="{'no_create': True, 'no_create_edit':True}"/>
                                <field name="y_item_group_id"  options="{'no_create': True, 'no_create_edit':True}"/>
                                <field name="y_start_date"/>
                            </group>
                            <group>
                                <field name="y_trade_discounts"/>
                                <field name="y_qty_disc"/>
                                <field name="y_spec_discount"/>
                                <field name="y_end_date"/>
                            </group>
                        </group>
                    </sheet>
                </form>     
			</field>
		</record>

        <record id="sh_pol_sale_doc_structure_inherit" model="ir.ui.view">
			<field name="name">discount structure</field>
			<field name="model">discount.structure</field>
			<field name="arch" type="xml">			
				    <list>
                        <field name="y_price_id"/>
                        <field name="y_doc_type_id"/>
                        <field name="y_item_group_id"/>

                        <field name="y_trade_discounts"/>
                        <field name="y_qty_disc"/>
                        <field name="y_spec_discount"/>
                        <field name="y_start_date"/>
                        <field name="y_end_date"/>
                    </list>
			</field>
		</record>

        <record id="price_group_view" model="ir.ui.view">
            <field name="name">Pricegroup</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <field name="category_id" position="after">
                    <field name = "y_price_group_id" context="{'filter_price_group':True}"  options="{'no_create': True, 'no_create_edit':True}"/>
                </field>                              
            </field>    
        </record>

        <!-- <record model="ir.ui.view" id="price_group_view">
            <field name="name">Pricegroup</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="report_custom_fields.customized_partner_form"/>
            <field name="arch" type="xml"> 
                <field name="gst_reg_type" position="after">
                    <field name = "price_group_id" context="{'filter_price_group':True}"  options="{'no_create': True, 'no_create_edit':True}"/>
                </field>
            </field>
        </record> -->

		<record id="discount_sale_structure_work" model="ir.actions.act_window">
            <field name="name">Sales Discount Structure</field>
            <field name="res_model">discount.structure</field>
            <field name="view_mode">list,form</field>            
        </record>	
	
 	<menuitem id="data_structure_sale" name="Discount structure" action="discount_sale_structure_work" parent="sale.menu_sale_config"/>

 	</data>
</odoo>
