<odoo>

    <record id="view_purchase_report_wizard" model="ir.ui.view">
        <field name="name">purchase.register.wizard.form</field>
        <field name="model">purchase.register.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="y_date_start"/>
                        <field name="y_choose_from" widget='radio' string="Choose From"/>
                        <field name="y_company_id" options="{'no_create': True, 'no_create_edit':True, 'no_open': True}" required="1"/>
                    </group>
                    <group>
                        <field name="y_date_end"/>
                        <field name="y_partner_id" invisible="y_choose_from != 'partner_id'" required="y_choose_from == 'partner_id'" widget="many2many_tags" options="{'no_create': True, 'no_create_edit':True, 'no_open': True}"/>
                        <field name="y_categ_id"  invisible="y_choose_from != 'categ_id'" required="y_choose_from == 'categ_id'"  widget="many2many_tags" options="{'no_create': True, 'no_create_edit':True, 'no_open': True}"/>
                        <field name="y_report_date" widget='radio'/>
                    </group>                  
                </group>
                <footer>
                    <button string="View Report" type="object" name="retrieve_purchase_register" class="oe_highlight"/>
                     <button string="Generate Xlsx Report" type="object" name="button_download_xlsx_report" class="oe_highlight"/>
                    <button string="Cancel" special="cancel" type="object" class="btn btn-secondary oe_inline"/>
                </footer>
            </form>
        </field>
    </record>
    
   
</odoo>
