<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================ -->
    <!-- PRODUCT TEMPLATE VIEWS                       -->
    <!-- (Both Distributor and Tally Integration)    -->
    <!-- ============================================ -->
    
    <!-- Product Template Form View -->
    <record id="view_product_template_form_integration" model="ir.ui.view">
        <field name="name">product.template.form.integration</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Add buttons in header -->
            <xpath expr="//header" position="inside">
                <!-- Existing Distributor button -->
                <button name="create_product" 
                        string="Publish to Distributor" 
                        type="object" 
                        class="btn-secondary"
                        invisible="not server_url"
                        icon="fa-share-alt"/>
                        
                <!-- New Tally button -->
                <button name="action_push_to_tally_single" 
                        string="Push to Tally" 
                        type="object" 
                        class="btn-primary"
                        icon="fa-cloud-upload"/>
            </xpath>
            
            <!-- Add Tally Sync Info Tab -->
            <xpath expr="//notebook" position="inside">
                <page string="Tally Sync" name="tally_sync">
                    <group>
                        <group>
                            <field name="tally_sync_status" widget="badge" 
                                   decoration-success="tally_sync_status == 'synced'"
                                   decoration-danger="tally_sync_status == 'failed'"
                                   decoration-warning="tally_sync_status == 'partial'"
                                   decoration-muted="tally_sync_status == 'not_synced'"/>
                            <field name="tally_sync_date"/>
                        </group>
                        <group>
                            <field name="tally_company_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group string="Last Sync Error" invisible="tally_sync_status != 'failed'">
                        <field name="tally_sync_error" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Product Template Tree View - Add Tally Status -->
    <record id="view_product_template_tree_tally" model="ir.ui.view">
        <field name="name">product.template.tree.tally</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="tally_sync_status" widget="badge" optional="show"
                       decoration-success="tally_sync_status == 'synced'"
                       decoration-danger="tally_sync_status == 'failed'"
                       decoration-warning="tally_sync_status == 'partial'"
                       decoration-muted="tally_sync_status == 'not_synced'"/>
            </xpath>
        </field>
    </record>

    <!-- Action for bulk push to Tally from list view -->
    <record id="action_product_template_push_to_tally_bulk" model="ir.actions.server">
        <field name="name">Push to Tally</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = records.action_push_to_tally_bulk()
        </field>
    </record>

</odoo>