        <record id="view_inherit_stock_location_primary" model="ir.ui.view">
            <field name="name">stock.location.inherit</field>
            <field name="model">stock.location</field>
            <field name="inherit_id" ref="stock.view_location_form"/>
            <field name="arch" type="xml">
                <field name="scrap_location" position="after">
                    <field name="stock_quant_location"/>
                </field>           
            </field>
        </record>

        <record id="view_inherit_account_journal_primary" model="ir.ui.view">
            <field name="name">account.journal.inherit</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet//field[@name='company_id']" position="after">
                    <group>
                        <div class="o_row">
                            <label for="journal_tally_id"/>
        
                            <div class="o_row o_align_items_center">
                                <field name="journal_tally_id"/>
        
                                <button name="action_generate_code"
                                        type="object"
                                        string="Generate Code"
                                        class="btn-primary ms-2"/>
                            </div>
                        </div>
                    </group>
                </xpath>
        
            </field>
        </record>
        


        <record id="view_inherit_purchase_order_api" model="ir.ui.view">
            <field name="name">purchase.order.inherit</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">

                <button name="button_confirm" position='after'>
                    <button name="action_type" string="Synchronize" type="object" class="oe_highlight"/>
                    <button name="accept_reciept" string="Accept Quantity" type="object" class="oe_highlight"/>
                    <button name="accept_bill" string="Accept Bill" type="object" class="oe_highlight"/>
                </button>

                <field name="partner_id" position="after">
                    <field name="sale_order_no"/>
                    <field name="sale_delivery_state"/>
                </field>

                <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="after" >
                    <field name="sale_delivered_qty"/>
                </xpath>

            </field>
        </record>


        <record id="view_inherit_product_template_primary" model="ir.ui.view">
            <field name="name">product.template.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="create_product" string="Publish" class="oe_highlight" type="object"/>
                </xpath>   
                <field name="categ_id" position="after">
                    <field name="company_names"/>
                    <field name="company_ids" widget="many2many_tags"/>
                </field>       
            </field>
        </record>
        <record id="action_publish_product" model="ir.actions.server">
                <field name="name">Publish</field>
                <field name="model_id" ref="product.model_product_template"/>
                <field name="binding_model_id" ref="product.model_product_template"/>
                <field name="binding_type">action</field>
                <field name="state">code</field>
                <field name="code">
                    action = records.create_product()
                </field>
            </record>
        <record id="view_inherit_product_template_tree" model="ir.ui.view">
            <field name="name">product.template.inherit.tree</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
                <!-- Add per-record Publish button inside list view -->
                <xpath expr="//list" position="inside">
                    <button name="create_product"
                            string="Publish"
                            type="object"
                            icon="fa-check"/>
                </xpath>
            </field>
        </record>

        <record id="view_inherit_product_category_primary" model="ir.ui.view">
            <field name="name">product.category.inherit</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="product.product_category_form_view"/>
            <field name="arch" type="xml">
                <field name="parent_id" position="after">
                    <field name="category_primary_key"/>
                </field>             
            </field>
        </record>


        <record id="product_distributor_access_rule" model="ir.rule">
            <field name="name">Product Distributor Rule</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="domain_force">['|',('company_ids','=',False),('company_ids', 'in', company_ids)]</field>  
        </record>

	</data>
</odoo>