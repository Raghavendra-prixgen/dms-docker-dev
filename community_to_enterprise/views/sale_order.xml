        <record id="duplicate_sale_order_form" model="ir.ui.view">
            <field name="name">duplicate.sale.order.form</field>
            <field name="model">duplicate.sale.order</field>
            <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_type" string="Synchronize" type="object" class="oe_highlight"/>
                    <button name="update_quantity" string="Update Quantity" type="object" class="oe_highlight"/>
                    <button name="create_vendor_bills" string="Create Bill" type="object" class="oe_highlight"/>
                </header>
                  <sheet>
                    <group>
                    <group>
                        <field name="company_id" string="Customer"/>
                        <field name="quotation_date" string="Quotation Date"/>
                        <field name="partner_shipping_id"/>
                    </group>
                    <group>
                        <field name="deliver_to" string="Deliver To"/>
                        <field name="address" string="Address"/>
                        <field name="currency_id"/>
                        <field name="delivery_state"/>
                        <field name='sale_order_no'/>
                    </group>
                    </group>
                    <notebook>
                        <page string="Order Lines">
                          <field name="duplicate_sale_order_line_ids">
                            <list editable="bottom" >
                              <field name="product_id" />
                              <field name="product_uom_qty" />
                              <field name="product_uom"/>
                              <field name="price_unit"/>
                              <field name="tax_id" widget="many2many_tags" />
                              <field name="price_subtotal"/>
                              <field name="price_tax"/>
                              <field name="price_total"/>
                            </list>
                          </field>
                          <group name="note_group" col="6" class="mt-2 mt-md-0">
                            <group class="oe_subtotal_footer oe_right" colspan="2" name="sale_total">
                              <field name="amount_untaxed" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                              <field name="amount_tax" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                              <field name="amount_total" widget='monetary' options="{'currency_field': 'currency_id'}"/>
                            </group>
                          </group>
                        </page>

                    </notebook>
                </sheet>
                  <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                  </div>
                </form>
            
            </field>
        </record>

        
        <record id="draft_filter" model="ir.ui.view">
        <field name="model">draft.partner</field>
        <field name="arch" type="xml">
            <search string="Draft Partner">
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

