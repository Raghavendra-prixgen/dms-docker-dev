		<record id="view_inherit_sale_order" model="ir.ui.view">
            <field name="name">sale.order.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <field name="partner_id" position="after">
                    <field name="duplicate_sale_entry_id"/>
                    <field name="delivery_status"/>
                </field>
                <xpath expr="//page/field[@name='order_line']/list/field[@name='product_id']" position="after">
                    <field name="duplicate_sale_line_entry_id"/>
                </xpath>
                
                <button name="action_cancel" position='after'>
                    <button name="action_type" string="Publish" type="object" class="oe_highlight"/>
                </button>
            </field>
        </record>
        
        <record model="ir.ui.view" id="res_company_inherit_vires">
            <field name="name">res company form view</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position='inside'>
                    <page string="Server">
                        <group>
                            <field name="server_db"/>
                            <field name="server_url"/>
                            <field name="user_name"/>
                            <field name="server_password"/>
                            
                            <label for="api_token">Api Token</label>
                            <div class="o_row">
                                <field name="api_token" string="Api Token"/>
                                <button name="action_generate_code" type="object" class="btn btn-primary fa fa-plus-square-o" aria-label="Creates New Api Token" title="Creates New Api Token" role="img" />
                                
                            </div>
                            <field name="tally_url" /> 
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
      
        <record id="view_inherit_res_partner_primary" model="ir.ui.view">
            <field name="name">res.partner.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <div name="button_box" position="inside">
                    <!-- <button class="oe_stat_button" 
                             type="object" 
                             icon="fa-tags"     
                             string="ByProduct Redeem"                    
                             name="action_by_product_redeem">
                    </button> -->
                    <!-- <button class="oe_stat_button" 
                             type="object" 
                             icon="fa-money"     
                             string="Redeem"                    
                             name="action_by_cash_redeem">
                    </button> -->
                </div>
                <field name="ref" position="after">
                    <field name="customer_primary_key"/>
                </field>  
                <xpath expr="//sheet/notebook" position="inside">
                    
                    <page name="Additional Information">
                        <group>
                            <group>
                                <field name="district_id"/>
                                <field name="taluk_id"/>
                            </group>
                        </group>
                    </page>
                    
                </xpath>   
                <xpath expr="/form/sheet/notebook/page[2]/group//field[@name='property_inbound_payment_method_line_id']" position="after">
                    <field name="y_is_distributor"/>
                </xpath>      
            </field>
        </record>

        <record id="res_partner_action" model="ir.actions.act_window">
            <field name="name">Redeem </field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">form</field>
          </record>


        <record id="view_inherit_res_company_primary" model="ir.ui.view">
            <field name="name">res.company.inherit</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <field name="phone" position="after">
                    <field name="company_primary_key" invisible="0"/>
                </field>       
            </field>
        </record>


        <record id="view_inherit_raccount_move_primary" model="ir.ui.view">
            <field name="name">account.move.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                
                <!-- <field name="partner_id" position="after">
                    <field name="sale_id"/>
                    <field name="duplicate_sale_entry_id"/>
                    <field name="tally_invoice_number"/>
                    <field name="tally_master_id"/>
                    <field name="company_primary_key" invisible="1"/>
                    <field name="tally_taxable_amount"/>
                    <field name="tally_tax_amount"/>
                    <field name="special_disc_on_sales"/>
                     -->
                    
                    
                   
                <!-- </field>   -->
                <xpath expr="//notebook" position='inside'>
                    <page string="Tally Info">
                        <group>
                            <group>
                                <field name="sale_id"/>
                                <field name="duplicate_sale_entry_id"/>
                                <field name="tally_invoice_number" readonly="1"/>
                                <field name="tally_master_id" readonly="1"/>
                                <field name="company_primary_key" readonly="1"/>
                                
                            </group>
                            <group>
                                <field name="company_code" invisible="1"/>
                                <field name="tally_taxable_amount"/>
                                <field name="tally_tax_amount"/>
                                <field name="special_disc_on_sales"/>
                                <field name="invoice_origin" readonly="1"/>
                                <field name="vch_primary_key" readonly="1"/> 
                                <field name="distributor_name" readonly="1" /> 
                            </group>
                        </group>
                    </page>
                </xpath>
                        


                <xpath expr="//notebook//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="after">
                    <field name="tally_product_name"/>
                    <field name="tally_product_code"/>
                </xpath>

                <xpath expr="//notebook//field[@name='invoice_line_ids']/list/field[@name='price_unit']" position="after">
                        <field name="cash_discount"/>
                        <field name="tally_amount"/>
                    </xpath>         
            </field>
        </record>
        <record id="view_invoice_list_inherit_distributor" model="ir.ui.view">
            <field name="name">account.move.list.inherit.distributor</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_partner_display_name']" position="after">
                    <field name="distributor_name" string="Distributor Name" optional="show"/>
                </xpath>
            </field>
        </record>

